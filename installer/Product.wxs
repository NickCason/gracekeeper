<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">
  <Package Name="GraceKeeper"
           Manufacturer="Nick Cason"
           Version="$(Version)"
           UpgradeCode="A1B2C3D4-E5F6-4789-A012-3456789ABCDE"
           Scope="perMachine"
           InstallerVersion="500">

    <MediaTemplate EmbedCab="yes"/>

    <MajorUpgrade DowngradeErrorMessage="A newer version of GraceKeeper is already installed."
                  Schedule="afterInstallInitialize"/>

    <Icon Id="appicon.ico" SourceFile="..\src\GraceKeeper.UI\Resources\gracekeeper.ico"/>

    <Feature Id="Main" Title="GraceKeeper" Level="1">
      <ComponentGroupRef Id="ProductComponents"/>
      <ComponentGroupRef Id="ProgramDataComponents"/>
      <ComponentGroupRef Id="ShortcutComponents"/>
    </Feature>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLDIR" Name="GraceKeeper"/>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="GK_PROGRAMMENU" Name="GraceKeeper"/>
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="GK_PROGRAMDATA" Name="GraceKeeper">
        <Directory Id="GK_LOGS" Name="logs"/>
      </Directory>
    </StandardDirectory>

    <ComponentGroup Id="ProductComponents" Directory="INSTALLDIR">
      <Component Id="DashboardExe" Guid="*">
        <File Source="..\src\GraceKeeper.UI\bin\Release\net48\GraceKeeper.exe" Id="GraceKeeper.exe" KeyPath="yes"/>
      </Component>
      <Component Id="DashboardConfig" Guid="*">
        <File Source="..\src\GraceKeeper.UI\bin\Release\net48\GraceKeeper.exe.config" Id="GraceKeeper.exe.config" KeyPath="yes"/>
      </Component>
      <Component Id="CoreDll" Guid="*">
        <File Source="..\src\GraceKeeper.UI\bin\Release\net48\GraceKeeper.Core.dll" Id="GraceKeeper.Core.dll" KeyPath="yes"/>
      </Component>
      <Component Id="HardcodetDll" Guid="*">
        <File Source="..\src\GraceKeeper.UI\bin\Release\net48\Hardcodet.NotifyIcon.Wpf.dll" Id="Hardcodet.NotifyIcon.Wpf.dll" KeyPath="yes"/>
      </Component>
      <Component Id="SysTextJsonDll" Guid="*">
        <File Source="..\src\GraceKeeper.UI\bin\Release\net48\System.Text.Json.dll" Id="System.Text.Json.dll" KeyPath="yes"/>
      </Component>
      <Component Id="SysTextEncodingsWebDll" Guid="*">
        <File Source="..\src\GraceKeeper.UI\bin\Release\net48\System.Text.Encodings.Web.dll" Id="System.Text.Encodings.Web.dll" KeyPath="yes"/>
      </Component>
      <Component Id="SysMemoryDll" Guid="*">
        <File Source="..\src\GraceKeeper.UI\bin\Release\net48\System.Memory.dll" Id="System.Memory.dll" KeyPath="yes"/>
      </Component>
      <Component Id="SysBuffersDll" Guid="*">
        <File Source="..\src\GraceKeeper.UI\bin\Release\net48\System.Buffers.dll" Id="System.Buffers.dll" KeyPath="yes"/>
      </Component>
      <Component Id="SysNumericsVectorsDll" Guid="*">
        <File Source="..\src\GraceKeeper.UI\bin\Release\net48\System.Numerics.Vectors.dll" Id="System.Numerics.Vectors.dll" KeyPath="yes"/>
      </Component>
      <Component Id="SysRuntimeCSUnsafeDll" Guid="*">
        <File Source="..\src\GraceKeeper.UI\bin\Release\net48\System.Runtime.CompilerServices.Unsafe.dll" Id="System.Runtime.CompilerServices.Unsafe.dll" KeyPath="yes"/>
      </Component>
      <Component Id="SysThreadingTasksExtDll" Guid="*">
        <File Source="..\src\GraceKeeper.UI\bin\Release\net48\System.Threading.Tasks.Extensions.dll" Id="System.Threading.Tasks.Extensions.dll" KeyPath="yes"/>
      </Component>
      <Component Id="SysValueTupleDll" Guid="*">
        <File Source="..\src\GraceKeeper.UI\bin\Release\net48\System.ValueTuple.dll" Id="System.ValueTuple.dll" KeyPath="yes"/>
      </Component>
      <Component Id="SysSecurityAccessControlDll" Guid="*">
        <File Source="..\src\GraceKeeper.UI\bin\Release\net48\System.Security.AccessControl.dll" Id="System.Security.AccessControl.dll" KeyPath="yes"/>
      </Component>
      <Component Id="SysSecurityPrincipalWindowsDll" Guid="*">
        <File Source="..\src\GraceKeeper.UI\bin\Release\net48\System.Security.Principal.Windows.dll" Id="System.Security.Principal.Windows.dll" KeyPath="yes"/>
      </Component>
      <Component Id="MsBclAsyncInterfacesDll" Guid="*">
        <File Source="..\src\GraceKeeper.UI\bin\Release\net48\Microsoft.Bcl.AsyncInterfaces.dll" Id="Microsoft.Bcl.AsyncInterfaces.dll" KeyPath="yes"/>
      </Component>
      <Component Id="MsWin32RegistryDll" Guid="*">
        <File Source="..\src\GraceKeeper.UI\bin\Release\net48\Microsoft.Win32.Registry.dll" Id="Microsoft.Win32.Registry.dll" KeyPath="yes"/>
      </Component>
      <Component Id="MsWin32SystemEventsDll" Guid="*">
        <File Source="..\src\GraceKeeper.UI\bin\Release\net48\Microsoft.Win32.SystemEvents.dll" Id="Microsoft.Win32.SystemEvents.dll" KeyPath="yes"/>
      </Component>
      <Component Id="AhkRuntime" Guid="*">
        <File Source="staging\AutoHotkey64.exe" Id="AutoHotkey64.exe" KeyPath="yes"/>
      </Component>
      <Component Id="DismisserAhk" Guid="*">
        <File Source="..\src\popup-dismisser.ahk" Id="popup_dismisser.ahk" Name="popup-dismisser.ahk" KeyPath="yes"/>
      </Component>
      <Component Id="CleanerExe" Guid="*">
        <File Source="..\src\GraceKeeper.Cleaner\bin\Release\net48\GraceKeeper.Cleaner.exe" Id="GraceKeeper.Cleaner.exe" KeyPath="yes"/>
      </Component>
      <Component Id="CleanerTasksScript" Guid="*">
        <File Source="..\src\register-cleaner-tasks.ps1" Id="register_cleaner_tasks.ps1" Name="register-cleaner-tasks.ps1" KeyPath="yes"/>
      </Component>
      <Component Id="LicenseFile" Guid="*">
        <File Source="..\LICENSE" Id="LICENSE" KeyPath="yes"/>
      </Component>
      <Component Id="ReadmeFile" Guid="*">
        <File Source="..\README.md" Id="README.md" KeyPath="yes"/>
      </Component>
      <!-- Autostart is now a Scheduled Task with a LogonTrigger (see
           CreateDashboardLogonTask custom action below). The previous HKLM\Run
           entry was subject to Windows 11 Startup Apps deferral, which delayed
           tray-app launch by 1-3 minutes after logon. -->
      <Component Id="LogonTaskScript" Guid="*">
        <File Source="..\src\register-logon-task.ps1" Id="register_logon_task.ps1" Name="register-logon-task.ps1" KeyPath="yes"/>
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="ProgramDataComponents">
      <!-- Permanent="yes": MSI creates these on install but never removes them
           on uninstall. The BA's UninstallConfirm "Remove all data" path is
           responsible for deleting %ProgramData%\GraceKeeper when the user
           opts in. See spec docs/superpowers/specs/2026-05-16-v0.2.0-installer-bootstrapper-design.md. -->
      <Component Id="ConfigJson" Directory="GK_PROGRAMDATA" Guid="*" Permanent="yes">
        <File Source="default-config.json" Id="config.json" Name="config.json" KeyPath="yes">
          <util:PermissionEx User="Users" GenericAll="yes"/>
        </File>
      </Component>
      <Component Id="LogsDir" Directory="GK_LOGS" Guid="B1C2D3E4-F5A6-4789-B012-3456789ABCDF" Permanent="yes">
        <CreateFolder>
          <util:PermissionEx User="Users" GenericAll="yes"/>
        </CreateFolder>
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="ShortcutComponents">
      <Component Id="StartMenuShortcut" Directory="GK_PROGRAMMENU" Guid="*">
        <Shortcut Id="GraceKeeperShortcut"
                  Name="GraceKeeper"
                  Target="[INSTALLDIR]GraceKeeper.exe"
                  WorkingDirectory="INSTALLDIR"
                  Icon="appicon.ico"/>
        <RemoveFolder Id="RemoveGkProgramMenu" On="uninstall"/>
        <RegistryValue Root="HKCU" Key="Software\GraceKeeper" Name="installed" Type="integer" Value="1" KeyPath="yes"/>
      </Component>
    </ComponentGroup>

    <CustomAction Id="CreateCleanerTasks"
                  Directory="INSTALLDIR"
                  ExeCommand='powershell.exe -NoProfile -ExecutionPolicy Bypass -File "[INSTALLDIR]register-cleaner-tasks.ps1"'
                  Execute="deferred"
                  Impersonate="no"
                  Return="check"/>

    <CustomAction Id="RemoveCleanupTask"
                  Directory="INSTALLDIR"
                  ExeCommand='schtasks.exe /Delete /F /TN "GraceKeeper - Cleanup RNL"'
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"/>

    <CustomAction Id="RemoveBootCleanupTask"
                  Directory="INSTALLDIR"
                  ExeCommand='schtasks.exe /Delete /F /TN "GraceKeeper - Boot Cleanup"'
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"/>

    <CustomAction Id="CreateDashboardLogonTask"
                  Directory="INSTALLDIR"
                  ExeCommand='powershell.exe -NoProfile -ExecutionPolicy Bypass -File "[INSTALLDIR]register-logon-task.ps1"'
                  Execute="deferred"
                  Impersonate="no"
                  Return="check"/>

    <CustomAction Id="RemoveDashboardLogonTask"
                  Directory="INSTALLDIR"
                  ExeCommand='schtasks.exe /Delete /F /TN "GraceKeeper - Dashboard Logon"'
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"/>

    <CustomAction Id="StopDismisser"
                  Directory="INSTALLDIR"
                  ExeCommand='taskkill.exe /F /IM AutoHotkey64.exe'
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"/>

    <!-- GraceKeeper.exe is a tray app (ShutdownMode=OnExplicitShutdown), so the
         user closing the window only hides it; the process keeps running and
         holds file locks on the installed binaries. Without this, an uninstall
         leaves the dashboard alive with a "ghost" window and defers all the
         file deletions until reboot. -->
    <CustomAction Id="StopDashboard"
                  Directory="INSTALLDIR"
                  ExeCommand='taskkill.exe /F /IM GraceKeeper.exe'
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore"/>

    <InstallExecuteSequence>
      <Custom Action="StopDashboard"       Before="RemoveFiles"       Condition="Installed AND (REMOVE=&quot;ALL&quot; OR UPGRADINGPRODUCTCODE)"/>
      <Custom Action="StopDismisser"       Before="RemoveFiles"       Condition="Installed AND (REMOVE=&quot;ALL&quot; OR UPGRADINGPRODUCTCODE)"/>
      <Custom Action="RemoveCleanupTask"        Before="RemoveFiles"  Condition="REMOVE=&quot;ALL&quot;"/>
      <Custom Action="RemoveBootCleanupTask"    Before="RemoveFiles"  Condition="REMOVE=&quot;ALL&quot;"/>
      <Custom Action="RemoveDashboardLogonTask" Before="RemoveFiles"  Condition="REMOVE=&quot;ALL&quot;"/>
      <Custom Action="CreateCleanerTasks"       After="InstallFiles"  Condition="NOT Installed"/>
      <Custom Action="CreateDashboardLogonTask" After="InstallFiles"  Condition="NOT Installed"/>
    </InstallExecuteSequence>

  </Package>
</Wix>
