<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Color x:Key="BgColor">#FF1A1A1A</Color>
  <Color x:Key="BgAltColor">#FF141414</Color>
  <Color x:Key="TitlebarColor">#FF0F0F0F</Color>
  <Color x:Key="BorderColor">#FF232323</Color>
  <Color x:Key="TextColor">#FFEAEAEA</Color>
  <Color x:Key="MutedTextColor">#FFAAAAAA</Color>
  <Color x:Key="AccentColor">#FFD22E3F</Color>
  <Color x:Key="AccentDarkColor">#FF7A0A14</Color>

  <SolidColorBrush x:Key="Bg" Color="{StaticResource BgColor}"/>
  <SolidColorBrush x:Key="BgAlt" Color="{StaticResource BgAltColor}"/>
  <SolidColorBrush x:Key="Titlebar" Color="{StaticResource TitlebarColor}"/>
  <SolidColorBrush x:Key="Border" Color="{StaticResource BorderColor}"/>
  <SolidColorBrush x:Key="Text" Color="{StaticResource TextColor}"/>
  <SolidColorBrush x:Key="MutedText" Color="{StaticResource MutedTextColor}"/>
  <SolidColorBrush x:Key="Accent" Color="{StaticResource AccentColor}"/>
  <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
    <GradientStop Color="{StaticResource AccentColor}" Offset="0"/>
    <GradientStop Color="{StaticResource AccentDarkColor}" Offset="1"/>
  </LinearGradientBrush>

  <Style x:Key="PrimaryButton" TargetType="Button">
    <Setter Property="Background" Value="{StaticResource AccentGradient}"/>
    <Setter Property="Foreground" Value="White"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="22,7"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{StaticResource MutedText}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="FontWeight" Value="Normal"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border Background="Transparent" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="3" Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>
