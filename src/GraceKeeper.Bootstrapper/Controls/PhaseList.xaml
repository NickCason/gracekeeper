<UserControl x:Class="GraceKeeper.Bootstrapper.Controls.PhaseList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="clr-namespace:GraceKeeper.Core;assembly=GraceKeeper.Core">
    <UserControl.Resources>
        <DataTemplate DataType="{x:Type core:PhaseRow}">
            <Grid Margin="0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="22"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" Width="16" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse x:Name="Dot" Width="6" Height="6" Fill="{StaticResource Border}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Grid x:Name="Spinner" Opacity="0">
                        <Grid.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotate" Angle="0" CenterX="8" CenterY="8"/>
                        </Grid.RenderTransform>
                        <Ellipse Stroke="{StaticResource Accent}" StrokeThickness="2" Opacity="0.25"/>
                        <Path Stroke="{StaticResource Accent}" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              Data="M 8 0 A 8 8 0 0 1 16 8"/>
                    </Grid>
                    <Path x:Name="Check" Stroke="{StaticResource Accent}" StrokeThickness="2" Opacity="0"
                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                          Data="M 1 8 L 6 13 L 14 3"/>
                </Grid>
                <TextBlock x:Name="TitleText" Grid.Column="1" Text="{Binding Title}" VerticalAlignment="Center"
                           FontSize="12" Foreground="{StaticResource MutedText}"/>
            </Grid>
            <DataTemplate.Triggers>
                <!-- FrameworkElement.Triggers (Grid.Triggers) only accepts
                     EventTrigger. DataTriggers belong in DataTemplate.Triggers,
                     which is also where we set the title color. Setters and
                     EnterActions can coexist on a single DataTrigger. -->
                <DataTrigger Binding="{Binding State}" Value="Active">
                    <Setter TargetName="TitleText" Property="Foreground" Value="{StaticResource Text}"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="Dot" Storyboard.TargetProperty="Opacity" To="0" Duration="{StaticResource Duration.Standard}"/>
                                <DoubleAnimation Storyboard.TargetName="Spinner" Storyboard.TargetProperty="Opacity" To="1" Duration="{StaticResource Duration.Standard}"/>
                                <DoubleAnimation Storyboard.TargetName="Check" Storyboard.TargetProperty="Opacity" To="0" Duration="{StaticResource Duration.Quick}"/>
                                <DoubleAnimation Storyboard.TargetName="SpinnerRotate" Storyboard.TargetProperty="Angle"
                                                 From="0" To="360" Duration="0:0:0.9" RepeatBehavior="Forever"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
                <DataTrigger Binding="{Binding State}" Value="Done">
                    <Setter TargetName="TitleText" Property="Foreground" Value="{StaticResource MutedText}"/>
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="Spinner" Storyboard.TargetProperty="Opacity" To="0" Duration="{StaticResource Duration.Quick}"/>
                                <DoubleAnimation Storyboard.TargetName="Dot" Storyboard.TargetProperty="Opacity" To="0" Duration="{StaticResource Duration.Quick}"/>
                                <DoubleAnimation Storyboard.TargetName="Check" Storyboard.TargetProperty="Opacity" To="1" Duration="{StaticResource Duration.Standard}"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </UserControl.Resources>
    <ItemsControl ItemsSource="{Binding Phases, RelativeSource={RelativeSource AncestorType=UserControl}}"/>
</UserControl>
