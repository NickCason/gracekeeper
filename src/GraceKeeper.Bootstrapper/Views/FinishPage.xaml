<UserControl x:Class="GraceKeeper.Bootstrapper.Views.FinishPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Bg}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Border Grid.Row="0" Background="{StaticResource Titlebar}" Padding="14,8" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
      <TextBlock Text="GraceKeeper Setup" FontSize="12" Foreground="#CCCCCC"/>
    </Border>
    <Grid Grid.Row="1" Margin="28,22,28,0">
      <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
      <Border Grid.Column="0" Width="32" Height="32" CornerRadius="7" Background="{StaticResource AccentGradient}">
        <TextBlock Text="GK" FontWeight="Bold" FontSize="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Border>
      <TextBlock Grid.Column="1" Text="GraceKeeper" FontSize="15" FontWeight="SemiBold" Margin="12,0,0,0" VerticalAlignment="Center"/>
    </Grid>
    <StackPanel Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="28,0">
      <Ellipse Width="64" Height="64" HorizontalAlignment="Center">
        <Ellipse.Fill>
          <RadialGradientBrush>
            <GradientStop Color="{StaticResource AccentColor}" Offset="0"/>
            <GradientStop Color="{StaticResource AccentDarkColor}" Offset="1"/>
          </RadialGradientBrush>
        </Ellipse.Fill>
      </Ellipse>
      <TextBlock Text="All set." FontSize="20" FontWeight="Light" Foreground="White" HorizontalAlignment="Center" Margin="0,14,0,0"/>
      <TextBlock Text="GraceKeeper is installed and starting now. Look for the GK icon in your system tray."
                 TextAlignment="Center" Foreground="{StaticResource MutedText}" FontSize="12" Margin="0,8,0,0" MaxWidth="380" TextWrapping="Wrap"/>
      <CheckBox Content="Launch GraceKeeper now" IsChecked="{Binding LaunchOnFinish, Mode=TwoWay}" Foreground="{StaticResource Text}" Margin="0,14,0,0" HorizontalAlignment="Center"/>
    </StackPanel>
    <Border Grid.Row="3" Background="{StaticResource BgAlt}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="28,12">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="Finish" Style="{StaticResource PrimaryButton}" Command="{Binding FinishCommand}"/>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
