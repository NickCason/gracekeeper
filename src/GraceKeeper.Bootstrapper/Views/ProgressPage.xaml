<UserControl x:Class="GraceKeeper.Bootstrapper.Views.ProgressPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctl="clr-namespace:GraceKeeper.Bootstrapper.Controls"
             Background="{StaticResource Bg}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <Border Grid.Row="0" Background="{StaticResource Titlebar}" Padding="14,8" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
      <TextBlock Text="GraceKeeper Setup" FontSize="12" Foreground="#CCCCCC"/>
    </Border>
    <Grid Grid.Row="1" Margin="28,22,28,0">
      <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
      <Border Grid.Column="0" Width="32" Height="32" CornerRadius="7" Background="{StaticResource AccentGradient}">
        <TextBlock Text="GK" FontWeight="Bold" FontSize="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Border>
      <TextBlock Grid.Column="1" Text="GraceKeeper" FontSize="15" FontWeight="SemiBold" Margin="12,0,0,0" VerticalAlignment="Center"/>
    </Grid>
    <StackPanel Grid.Row="2" VerticalAlignment="Center" Margin="28,0,28,0">
      <TextBlock Text="Installing&#x2026;" FontSize="18" FontWeight="Light" Foreground="White"/>
      <Grid Margin="0,22,0,0" Height="4">
        <ProgressBar Minimum="0" Maximum="100" Value="{Binding SmoothedPercent}"
                     Background="#FF2A2A2A" Foreground="{StaticResource Accent}" BorderThickness="0"/>
        <Rectangle IsHitTestVisible="False">
          <Rectangle.Style>
            <Style TargetType="Rectangle">
              <Setter Property="Visibility" Value="Collapsed"/>
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                  <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </Rectangle.Style>
          <Rectangle.Fill>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
              <GradientStop x:Name="ShimmerStart" Color="#00FFFFFF" Offset="-0.3"/>
              <GradientStop x:Name="ShimmerMid" Color="#2EFFFFFF" Offset="0.0"/>
              <GradientStop x:Name="ShimmerEnd" Color="#00FFFFFF" Offset="0.3"/>
            </LinearGradientBrush>
          </Rectangle.Fill>
          <Rectangle.Triggers>
            <EventTrigger RoutedEvent="FrameworkElement.Loaded">
              <BeginStoryboard>
                <Storyboard RepeatBehavior="Forever">
                  <DoubleAnimation Storyboard.TargetName="ShimmerStart" Storyboard.TargetProperty="Offset" From="-0.3" To="1.0" Duration="0:0:1.8"/>
                  <DoubleAnimation Storyboard.TargetName="ShimmerMid" Storyboard.TargetProperty="Offset" From="0.0" To="1.3" Duration="0:0:1.8"/>
                  <DoubleAnimation Storyboard.TargetName="ShimmerEnd" Storyboard.TargetProperty="Offset" From="0.3" To="1.6" Duration="0:0:1.8"/>
                </Storyboard>
              </BeginStoryboard>
            </EventTrigger>
          </Rectangle.Triggers>
        </Rectangle>
      </Grid>
      <ctl:PhaseList Phases="{Binding Phases}" Margin="0,20,0,0"/>
      <TextBlock Text="{Binding StatusText}" Margin="0,16,0,0" FontSize="11" Foreground="{StaticResource MutedText}" FontFamily="Consolas"/>
    </StackPanel>
    <Border Grid.Row="3" Background="{StaticResource BgAlt}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="28,12">
      <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="{Binding TimeRemaining}" Foreground="#666666" FontSize="11" VerticalAlignment="Center"/>
        <Button Grid.Column="1" Content="Cancel" Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}"/>
      </Grid>
    </Border>
  </Grid>
</UserControl>
