<UserControl x:Class="GraceKeeper.Bootstrapper.Views.WelcomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource Bg}">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource Titlebar}" Padding="14,8" BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
      <Grid>
        <TextBlock Text="GraceKeeper Setup" FontSize="12" Foreground="#CCCCCC"/>
      </Grid>
    </Border>

    <Grid Grid.Row="1" Margin="28,22,28,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <Border Grid.Column="0" Width="32" Height="32" CornerRadius="7" Background="{StaticResource AccentGradient}">
        <TextBlock Text="GK" FontWeight="Bold" FontSize="14" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
      </Border>
      <TextBlock Grid.Column="1" Text="GraceKeeper" FontSize="15" FontWeight="SemiBold" Margin="12,0,0,0" VerticalAlignment="Center"/>
      <TextBlock Grid.Column="2" Text="{Binding Version}" FontSize="11" Foreground="{StaticResource MutedText}" VerticalAlignment="Center"/>
    </Grid>

    <Grid Grid.Row="2" Margin="28,18,28,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <StackPanel Grid.Row="0" Orientation="Horizontal">
        <StackPanel.Resources>
          <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="Light"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Opacity" Value="0"/>
            <Setter Property="RenderTransform">
              <Setter.Value>
                <TranslateTransform Y="8"/>
              </Setter.Value>
            </Setter>
          </Style>
        </StackPanel.Resources>
        <StackPanel.Triggers>
          <EventTrigger RoutedEvent="FrameworkElement.Loaded">
            <BeginStoryboard>
              <Storyboard>
                <DoubleAnimation Storyboard.TargetName="W1" Storyboard.TargetProperty="Opacity" From="0" To="1" BeginTime="0:0:0" Duration="{StaticResource Duration.Slow}" EasingFunction="{StaticResource Easing.Standard}"/>
                <DoubleAnimation Storyboard.TargetName="W1" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="8" To="0" BeginTime="0:0:0" Duration="{StaticResource Duration.Slow}" EasingFunction="{StaticResource Easing.Standard}"/>
                <DoubleAnimation Storyboard.TargetName="W2" Storyboard.TargetProperty="Opacity" From="0" To="1" BeginTime="0:0:0.06" Duration="{StaticResource Duration.Slow}" EasingFunction="{StaticResource Easing.Standard}"/>
                <DoubleAnimation Storyboard.TargetName="W2" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="8" To="0" BeginTime="0:0:0.06" Duration="{StaticResource Duration.Slow}" EasingFunction="{StaticResource Easing.Standard}"/>
                <DoubleAnimation Storyboard.TargetName="W3" Storyboard.TargetProperty="Opacity" From="0" To="1" BeginTime="0:0:0.12" Duration="{StaticResource Duration.Slow}" EasingFunction="{StaticResource Easing.Standard}"/>
                <DoubleAnimation Storyboard.TargetName="W3" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="8" To="0" BeginTime="0:0:0.12" Duration="{StaticResource Duration.Slow}" EasingFunction="{StaticResource Easing.Standard}"/>
                <DoubleAnimation Storyboard.TargetName="W4" Storyboard.TargetProperty="Opacity" From="0" To="1" BeginTime="0:0:0.18" Duration="{StaticResource Duration.Slow}" EasingFunction="{StaticResource Easing.Standard}"/>
                <DoubleAnimation Storyboard.TargetName="W4" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="8" To="0" BeginTime="0:0:0.18" Duration="{StaticResource Duration.Slow}" EasingFunction="{StaticResource Easing.Standard}"/>
                <DoubleAnimation Storyboard.TargetName="W5" Storyboard.TargetProperty="Opacity" From="0" To="1" BeginTime="0:0:0.24" Duration="{StaticResource Duration.Slow}" EasingFunction="{StaticResource Easing.Standard}"/>
                <DoubleAnimation Storyboard.TargetName="W5" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="8" To="0" BeginTime="0:0:0.24" Duration="{StaticResource Duration.Slow}" EasingFunction="{StaticResource Easing.Standard}"/>
              </Storyboard>
            </BeginStoryboard>
          </EventTrigger>
        </StackPanel.Triggers>
        <TextBlock x:Name="W1" Text="Keep" Margin="0,0,8,0"/>
        <TextBlock x:Name="W2" Text="the" Margin="0,0,8,0"/>
        <TextBlock x:Name="W3" Text="grace" Margin="0,0,8,0"/>
        <TextBlock x:Name="W4" Text="period" Margin="0,0,8,0"/>
        <TextBlock x:Name="W5" Text="alive." Foreground="{StaticResource Accent}"/>
      </StackPanel>
      <TextBlock Grid.Row="1" Margin="0,12,0,0" FontSize="12" Foreground="{StaticResource MutedText}" TextWrapping="Wrap">
        GraceKeeper automatically dismisses FactoryTalk activation popups and cleans .rnl refreshment files on a schedule. It runs in your system tray and stays out of the way.
      </TextBlock>
      <Border Grid.Row="2" Margin="0,14,0,0" Background="#FF232323" BorderBrush="#FF2E2E2E" BorderThickness="1" CornerRadius="3" Padding="12,10">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <TextBlock Foreground="#FFBBBBBB" FontFamily="Consolas" FontSize="11" TextWrapping="Wrap" Text="{Binding LicenseText}"/>
        </ScrollViewer>
      </Border>
      <CheckBox Grid.Row="3" Margin="0,10,0,0" Content="I accept the license terms" Foreground="{StaticResource Text}"
                IsChecked="{Binding AcceptedLicense, Mode=TwoWay}" FontSize="11"/>
    </Grid>

    <Border Grid.Row="3" Background="{StaticResource BgAlt}" BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0" Padding="28,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="Installs to C:\Program Files\GraceKeeper" Foreground="#666666" FontSize="11" VerticalAlignment="Center"/>
        <StackPanel Grid.Column="1" Orientation="Horizontal">
          <Button Content="Cancel" Style="{StaticResource SecondaryButton}" Command="{Binding CancelCommand}" Margin="0,0,8,0"/>
          <Button Content="Install" Style="{StaticResource PrimaryButton}" Command="{Binding InstallCommand}"/>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</UserControl>
