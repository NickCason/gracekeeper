<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="Bg.Page" Color="#D8DCE2"/>
    <SolidColorBrush x:Key="Bg.Surface" Color="#EAECF0"/>
    <SolidColorBrush x:Key="Border.Default" Color="#C4C9D2"/>
    <SolidColorBrush x:Key="Text.Primary" Color="#1A1D23"/>
    <SolidColorBrush x:Key="Text.Muted" Color="#6E7787"/>
    <SolidColorBrush x:Key="Brand.Red" Color="#8B1424"/>
    <SolidColorBrush x:Key="Brand.RedHover" Color="#6F0F1D"/>
    <SolidColorBrush x:Key="Semantic.Good" Color="#15803D"/>
    <SolidColorBrush x:Key="Semantic.Warn" Color="#B45309"/>
    <SolidColorBrush x:Key="Semantic.Bad" Color="#B91C1C"/>
    <SolidColorBrush x:Key="Tag.DismissBg" Color="#F4D4D9"/>
    <SolidColorBrush x:Key="Tag.DismissFg" Color="#8B1424"/>
    <SolidColorBrush x:Key="Tag.CleanBg" Color="#D6E3F4"/>
    <SolidColorBrush x:Key="Tag.CleanFg" Color="#1E40AF"/>
    <SolidColorBrush x:Key="Button.SecondaryBg" Color="#EAECF0"/>

    <!-- Animation tokens -->
    <Duration x:Key="Duration.Quick">0:0:0.12</Duration>
    <Duration x:Key="Duration.Standard">0:0:0.24</Duration>
    <Duration x:Key="Duration.Slow">0:0:0.48</Duration>
    <Duration x:Key="Duration.Counter">0:0:1.2</Duration>
    <Duration x:Key="Duration.Pulse">0:0:1.6</Duration>

    <CubicEase x:Key="Easing.Standard" EasingMode="EaseOut"/>
    <QuinticEase x:Key="Easing.Decelerate" EasingMode="EaseOut"/>
</ResourceDictionary>
