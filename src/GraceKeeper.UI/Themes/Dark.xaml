<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <SolidColorBrush x:Key="Bg.Page" Color="#14171C"/>
    <SolidColorBrush x:Key="Bg.Surface" Color="#1C2028"/>
    <SolidColorBrush x:Key="Border.Default" Color="#232730"/>
    <SolidColorBrush x:Key="Text.Primary" Color="#F3F6FA"/>
    <SolidColorBrush x:Key="Text.Muted" Color="#8A93A3"/>
    <SolidColorBrush x:Key="Brand.Red" Color="#A01828"/>
    <SolidColorBrush x:Key="Brand.RedHover" Color="#861320"/>
    <SolidColorBrush x:Key="Semantic.Good" Color="#4ADE80"/>
    <SolidColorBrush x:Key="Semantic.Warn" Color="#FBBF24"/>
    <SolidColorBrush x:Key="Semantic.Bad" Color="#F87171"/>
    <SolidColorBrush x:Key="Tag.DismissBg" Color="#3D1A1F"/>
    <SolidColorBrush x:Key="Tag.DismissFg" Color="#E89AA5"/>
    <SolidColorBrush x:Key="Tag.CleanBg" Color="#1A2B47"/>
    <SolidColorBrush x:Key="Tag.CleanFg" Color="#60A5FA"/>
    <SolidColorBrush x:Key="Button.SecondaryBg" Color="#1C2028"/>

    <!-- Animation tokens -->
    <Duration x:Key="Duration.Quick">0:0:0.12</Duration>
    <Duration x:Key="Duration.Standard">0:0:0.24</Duration>
    <Duration x:Key="Duration.Slow">0:0:0.48</Duration>
    <Duration x:Key="Duration.Counter">0:0:1.2</Duration>
    <Duration x:Key="Duration.Pulse">0:0:1.6</Duration>

    <CubicEase x:Key="Easing.Standard" EasingMode="EaseOut"/>
    <QuinticEase x:Key="Easing.Decelerate" EasingMode="EaseOut"/>
</ResourceDictionary>
