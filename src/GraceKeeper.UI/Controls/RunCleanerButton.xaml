<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:ctl="clr-namespace:GraceKeeper.UI.Controls">
    <Style TargetType="{x:Type ctl:RunCleanerButton}">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="14,8"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ctl:RunCleanerButton}">
                    <!-- Main Border wraps content so it sizes correctly to its
                         children. The Done-state green tint is a sibling Border
                         layered over it via the parent Grid, opacity-faded in
                         when State=Done. -->
                    <Grid>
                        <Border x:Name="RedBg"
                                Background="{DynamicResource Brand.Red}"
                                CornerRadius="4">
                            <StackPanel Orientation="Horizontal"
                                        Margin="{TemplateBinding Padding}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <Grid x:Name="Spinner" Width="14" Height="14" Margin="0,0,8,0" Opacity="0">
                                    <Grid.RenderTransform>
                                        <RotateTransform x:Name="SpinnerRotate" Angle="0" CenterX="7" CenterY="7"/>
                                    </Grid.RenderTransform>
                                    <Ellipse Stroke="White" StrokeThickness="2" Opacity="0.25"/>
                                    <Path Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                          Data="M 7 0 A 7 7 0 0 1 14 7"/>
                                </Grid>
                                <Path x:Name="Check" Stroke="White" StrokeThickness="2" Margin="0,0,8,0"
                                      StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M 0 6 L 4 10 L 11 2" Opacity="0"/>
                                <TextBlock x:Name="Label" Text="Run cleaner now"
                                           Foreground="{TemplateBinding Foreground}"
                                           FontWeight="{TemplateBinding FontWeight}"/>
                            </StackPanel>
                        </Border>
                        <Border x:Name="GreenBg"
                                Background="{DynamicResource Semantic.Good}"
                                CornerRadius="4"
                                Opacity="0"
                                IsHitTestVisible="False"/>
                        <Border x:Name="RedFailBg"
                                Background="{DynamicResource Semantic.Bad}"
                                CornerRadius="4"
                                Opacity="0"
                                IsHitTestVisible="False"/>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup Name="CleanerStates">
                                <VisualState Name="Idle">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Spinner" Storyboard.TargetProperty="Opacity" To="0" Duration="{StaticResource Duration.Standard}"/>
                                        <DoubleAnimation Storyboard.TargetName="Check" Storyboard.TargetProperty="Opacity" To="0" Duration="{StaticResource Duration.Standard}"/>
                                        <DoubleAnimation Storyboard.TargetName="GreenBg" Storyboard.TargetProperty="Opacity" To="0" Duration="{StaticResource Duration.Standard}"/>
                                        <DoubleAnimation Storyboard.TargetName="RedFailBg" Storyboard.TargetProperty="Opacity" To="0" Duration="{StaticResource Duration.Standard}"/>
                                        <StringAnimationUsingKeyFrames Storyboard.TargetName="Label" Storyboard.TargetProperty="Text" Duration="0:0:0">
                                            <DiscreteStringKeyFrame KeyTime="0:0:0" Value="Run cleaner now"/>
                                        </StringAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState Name="Running">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Spinner" Storyboard.TargetProperty="Opacity" To="1" Duration="{StaticResource Duration.Standard}"/>
                                        <DoubleAnimation Storyboard.TargetName="Check" Storyboard.TargetProperty="Opacity" To="0" Duration="{StaticResource Duration.Quick}"/>
                                        <DoubleAnimation Storyboard.TargetName="GreenBg" Storyboard.TargetProperty="Opacity" To="0" Duration="{StaticResource Duration.Standard}"/>
                                        <DoubleAnimation Storyboard.TargetName="RedFailBg" Storyboard.TargetProperty="Opacity" To="0" Duration="{StaticResource Duration.Standard}"/>
                                        <DoubleAnimation Storyboard.TargetName="SpinnerRotate" Storyboard.TargetProperty="Angle"
                                                         From="0" To="360" Duration="0:0:0.9" RepeatBehavior="Forever"/>
                                        <StringAnimationUsingKeyFrames Storyboard.TargetName="Label" Storyboard.TargetProperty="Text" Duration="0:0:0">
                                            <DiscreteStringKeyFrame KeyTime="0:0:0" Value="Cleaning&#8230;"/>
                                        </StringAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState Name="Done">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Spinner" Storyboard.TargetProperty="Opacity" To="0" Duration="{StaticResource Duration.Quick}"/>
                                        <DoubleAnimation Storyboard.TargetName="Check" Storyboard.TargetProperty="Opacity" To="1" Duration="{StaticResource Duration.Standard}"/>
                                        <DoubleAnimation Storyboard.TargetName="GreenBg" Storyboard.TargetProperty="Opacity" To="1" Duration="{StaticResource Duration.Standard}"/>
                                        <DoubleAnimation Storyboard.TargetName="RedFailBg" Storyboard.TargetProperty="Opacity" To="0" Duration="{StaticResource Duration.Standard}"/>
                                        <StringAnimationUsingKeyFrames Storyboard.TargetName="Label" Storyboard.TargetProperty="Text" Duration="0:0:0">
                                            <DiscreteStringKeyFrame KeyTime="0:0:0" Value="Done"/>
                                        </StringAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState Name="Failed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Spinner" Storyboard.TargetProperty="Opacity" To="0" Duration="{StaticResource Duration.Quick}"/>
                                        <DoubleAnimation Storyboard.TargetName="Check" Storyboard.TargetProperty="Opacity" To="0" Duration="{StaticResource Duration.Standard}"/>
                                        <DoubleAnimation Storyboard.TargetName="GreenBg" Storyboard.TargetProperty="Opacity" To="0" Duration="{StaticResource Duration.Standard}"/>
                                        <DoubleAnimation Storyboard.TargetName="RedFailBg" Storyboard.TargetProperty="Opacity" To="1" Duration="{StaticResource Duration.Standard}"/>
                                        <StringAnimationUsingKeyFrames Storyboard.TargetName="Label" Storyboard.TargetProperty="Text" Duration="0:0:0">
                                            <DiscreteStringKeyFrame KeyTime="0:0:0" Value="Failed"/>
                                        </StringAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
