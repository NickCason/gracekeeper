<Page x:Class="GraceKeeper.UI.Views.SettingsView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:GraceKeeper.UI.ViewModels"
      Background="{DynamicResource Bg.Page}"
      Foreground="{DynamicResource Text.Primary}">
    <Page.DataContext>
        <vm:SettingsViewModel/>
    </Page.DataContext>
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="← Back to dashboard" Click="Back_Click" Padding="8,4"
                    Background="{DynamicResource Button.SecondaryBg}"
                    Foreground="{DynamicResource Text.Primary}"
                    BorderBrush="{DynamicResource Border.Default}"/>
        </StackPanel>

        <StackPanel>
            <TextBlock Text="SCHEDULE" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource Text.Muted}" Margin="0,0,0,8"/>
            <Border Background="{DynamicResource Bg.Surface}"
                    BorderBrush="{DynamicResource Border.Default}" BorderThickness="1"
                    CornerRadius="8" Padding="14" Margin="0,0,0,16">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Cleaner interval (minutes)" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding IntervalMinutes, UpdateSourceTrigger=PropertyChanged}"
                                 Width="100" HorizontalAlignment="Left"/>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Start time (HH:mm)" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding StartTime, UpdateSourceTrigger=PropertyChanged}"
                                 Width="100" HorizontalAlignment="Left"/>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="THEME" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource Text.Muted}" Margin="0,0,0,8"/>
            <Border Background="{DynamicResource Bg.Surface}"
                    BorderBrush="{DynamicResource Border.Default}" BorderThickness="1"
                    CornerRadius="8" Padding="14" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal">
                    <RadioButton GroupName="Theme" Content="Follow Windows"
                                 IsChecked="{Binding Theme, Converter={x:Static vm:ThemeRadioConverter.Auto}}"
                                 Margin="0,0,16,0"/>
                    <RadioButton GroupName="Theme" Content="Light"
                                 IsChecked="{Binding Theme, Converter={x:Static vm:ThemeRadioConverter.Light}}"
                                 Margin="0,0,16,0"/>
                    <RadioButton GroupName="Theme" Content="Dark"
                                 IsChecked="{Binding Theme, Converter={x:Static vm:ThemeRadioConverter.Dark}}"/>
                </StackPanel>
            </Border>

            <TextBlock Text="ABOUT" FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource Text.Muted}" Margin="0,0,0,8"/>
            <Border Background="{DynamicResource Bg.Surface}"
                    BorderBrush="{DynamicResource Border.Default}" BorderThickness="1"
                    CornerRadius="8" Padding="14" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock>
                        <Run Text="Version: "/>
                        <Run Text="{Binding Version, Mode=OneTime}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <TextBlock Margin="0,4,0,0">
                        <Hyperlink Click="OpenGitHub_Click">View on GitHub</Hyperlink>
                    </TextBlock>
                    <TextBlock Margin="0,4,0,0">
                        <Hyperlink Click="OpenInstallDir_Click">Open install folder</Hyperlink>
                    </TextBlock>
                    <TextBlock Margin="0,4,0,0">
                        <Hyperlink Click="OpenLogDir_Click">Open log folder</Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Button Content="Save" Click="Save_Click"
                    Background="{DynamicResource Brand.Red}" Foreground="White"
                    Padding="14,8" HorizontalAlignment="Left" BorderThickness="0"/>
        </StackPanel>
    </DockPanel>
</Page>
