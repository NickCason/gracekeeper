<Application x:Class="GraceKeeper.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:tb="http://www.hardcodet.net/taskbar"
             Startup="OnStartup"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Light.xaml" />
                <ResourceDictionary Source="Controls/AnimatedCounter.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <tb:TaskbarIcon x:Key="TrayIcon"
                            IconSource="/Resources/gracekeeper.ico"
                            ToolTipText="GraceKeeper"
                            TrayMouseDoubleClick="TrayIcon_DoubleClick">
                <tb:TaskbarIcon.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Open dashboard" Click="OpenWindow_Click"/>
                        <MenuItem Header="Pause" Click="Pause_Click"/>
                        <MenuItem Header="Run cleaner now" Click="RunCleanerNow_Click"/>
                        <Separator/>
                        <MenuItem Header="Settings" Click="OpenSettings_Click"/>
                        <Separator/>
                        <MenuItem Header="Exit" Click="Exit_Click"/>
                    </ContextMenu>
                </tb:TaskbarIcon.ContextMenu>
            </tb:TaskbarIcon>
        </ResourceDictionary>
    </Application.Resources>
</Application>
